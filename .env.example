# === BACKEND ===
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# === DATABASE ===
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mandimitra
MONGODB_DB_NAME=mandimitra

# === CACHE ===
UPSTASH_REDIS_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# === ML MODEL ===
MODEL_PATH=./ml/saved_models/lstm_attention_v1.pt
SCALER_PATH=./ml/saved_models/scaler.pkl
HUGGINGFACE_REPO=your-hf-username/mandimitra-model

# === EXTERNAL APIs ===
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
# No key needed for Open-Meteo — completely free

# === FRONTEND ===
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=MandiMitra XAI
